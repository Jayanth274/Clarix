{
  "name": "cognitive-waste-analyzer",
  "version": "1.0.0",
  "description": "UX Cognitive Load Intelligence Platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
